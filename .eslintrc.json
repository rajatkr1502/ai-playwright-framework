{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "plugins": ["@typescript-eslint"],
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended"
  ],
  "env": {
    "node": true,
    "es2022": true
  },
  "ignorePatterns": ["node_modules/", "allure-report/", "allure-results/", "playwright-report/", "test-results/"],
  "rules": {
    "no-console": "off"
  }
}
